model User {
  id        String   @id
  name      String?
  handle    String?
  image     String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Memory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  name      String
  message   String
  email     String?
  photoUrl  String?
  likeCount Int      @default(0)

  @@index([createdAt])
}

model Rsvp {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  firstName String
  lastName  String
  attending Boolean
  email     String?
  phone     String?
  note      String?

  @@index([createdAt])
}